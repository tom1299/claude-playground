{
  "name": "Claude Code Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "USER_UID": "1000",
      "USER_GID": "1000",
      "USERNAME": "${localEnv:USER}"
    }
  },
  "runArgs": [
    "--network=host",
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"
  ],
  "remoteUser": "${localEnv:USER}",
  "mounts": [
    "source=${localEnv:HOME}/.claude.json,target=${localEnv:HOME}/.claude.json,type=bind",
    "source=${localEnv:HOME}/.kube,target=${localEnv:HOME}/.kube,type=bind"
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/${localEnv:HOME}/git/github/claude-playground/skills/fix-vulnerabilities/vul-functions,type=bind,consistency=delegated",
  "workspaceFolder": "${localEnv:HOME}/git/github/claude-playground/skills/fix-vulnerabilities/vul-functions"
}
